# .athenaeum/<topic>/<agent>.vote.yaml — written ONLY by that agent.
agent: <canonical-slug>
artifact_sha256: <hash this agent computed>
decision: SIGN                  # SIGN | DISSENT
timestamp: <ISO8601 UTC>

# Present ONLY when decision is DISSENT:
dissent:
  - atom:
      section: "<section or heading>"
      anchor: "<quoted span locating objection>"
    objection: <what is wrong, concretely>
    proposed_resolution: carve-caveat   # verifier | ticket | rewrite | carve-caveat
